<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#0F0F1A">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ProxyBox TV"
        android:textColor="#E0E0FF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Profiles List -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Profile"
                android:textColor="#7C6FFF"
                android:textSize="18sp"
                android:layout_marginBottom="12dp"/>

            <ListView
                android:id="@+id/lvProfiles"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="#222"
                android:dividerHeight="1dp"
                android:drawSelectorOnTop="false"
                android:listSelector="@android:color/transparent"
                android:focusable="true"
                android:nextFocusRight="@id/btnConnect"/>

            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="No profiles. Click Add Config."
                android:textColor="#888"
                android:textSize="16sp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Action Panel — scrollable -->
        <ScrollView
            android:layout_width="260dp"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none"
            android:background="#1A1A2E"
            android:focusable="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Not connected"
                    android:textColor="#888888"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btnConnect"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Connect"
                    android:textSize="18sp"
                    android:layout_marginBottom="10dp"
                    android:backgroundTint="#7C6FFF"
                    android:textColor="#FFF"
                    android:focusable="true"
                    android:nextFocusLeft="@id/lvProfiles"/>

                <Button
                    android:id="@+id/btnAddConfig"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Add Config via Phone"
                    android:textSize="13sp"
                    android:background="@drawable/tv_btn_focus"
                    android:textColor="#E0E0FF"
                    android:focusable="true"
                    android:nextFocusLeft="@id/lvProfiles"/>

                <Button
                    android:id="@+id/btnPingAll"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:text="Ping All"
                    android:textSize="13sp"
                    android:background="@drawable/tv_btn_focus"
                    android:textColor="#A78BFA"
                    android:focusable="true"
                    android:nextFocusLeft="@id/lvProfiles"/>

                <Button
                    android:id="@+id/btnTestConnection"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:text="Test Connection"
                    android:textSize="13sp"
                    android:background="@drawable/tv_btn_focus"
                    android:textColor="#4ADE80"
                    android:focusable="true"
                    android:nextFocusLeft="@id/lvProfiles"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="6dp"
                    android:background="#333"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Routing Preset"
                    android:textColor="#7C6FFF"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <Spinner
                    android:id="@+id/spinnerPreset"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/tv_btn_focus"
                    android:popupBackground="#2A2A4A"
                    android:focusable="true"
                    android:nextFocusLeft="@id/lvProfiles"/>

                <Button
                    android:id="@+id/btnIpCheck"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:text="IP Check"
                    android:textSize="14sp"
                    android:background="@drawable/tv_btn_focus"
                    android:textColor="#F59E0B"
                    android:focusable="true"
                    android:nextFocusLeft="@id/lvProfiles"/>

                <Button
                    android:id="@+id/btnUpdateGeo"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:text="Update Geo DB"
                    android:textSize="13sp"
                    android:background="@drawable/tv_btn_focus"
                    android:textColor="#60A5FA"
                    android:focusable="true"
                    android:nextFocusLeft="@id/lvProfiles"/>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>
</LinearLayout>
