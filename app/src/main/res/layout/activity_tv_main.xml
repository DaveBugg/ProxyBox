<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#0F0F1A">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/tv_title"
        android:textColor="#E0E0FF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Profiles List -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/select_profile"
                android:textColor="#7C6FFF"
                android:textSize="18sp"
                android:layout_marginBottom="12dp"/>

            <ListView
                android:id="@+id/lvProfiles"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="#222"
                android:dividerHeight="1dp"
                android:drawSelectorOnTop="false"
                android:listSelector="@android:color/transparent"
                android:focusable="true"
                android:nextFocusRight="@id/btnConnect"/>

            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="@string/no_profiles_tv"
                android:textColor="#888"
                android:textSize="16sp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Action Panel — scrollable -->
        <ScrollView
            android:layout_width="260dp"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none"
            android:background="#1A1A2E"
            android:focusable="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/not_connected"
                    android:textColor="#888888"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btnConnect"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="@string/connect"
                    android:textSize="18sp"
                    android:layout_marginBottom="10dp"
                    android:backgroundTint="#7C6FFF"
                    android:textColor="#FFF"
                    android:focusable="true"
                    android:nextFocusLeft="@id/lvProfiles"/>

                <Button
                    android:id="@+id/btnAddConfig"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="@string/add_config_phone"
                    android:textSize="13sp"
                    android:background="@drawable/tv_btn_focus"
                    android:textColor="#E0E0FF"
                    android:focusable="true"
                    android:nextFocusLeft="@id/lvProfiles"/>

                <Button
                    android:id="@+id/btnPingAll"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:text="@string/ping_all"
                    android:textSize="13sp"
                    android:background="@drawable/tv_btn_focus"
                    android:textColor="#A78BFA"
                    android:focusable="true"
                    android:nextFocusLeft="@id/lvProfiles"/>

                <Button
                    android:id="@+id/btnTestConnection"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:text="@string/test_connection"
                    android:textSize="13sp"
                    android:background="@drawable/tv_btn_focus"
                    android:textColor="#4ADE80"
                    android:focusable="true"
                    android:nextFocusLeft="@id/lvProfiles"/>

                <Button
                    android:id="@+id/btnSpeedTest"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:text="@string/speed_test"
                    android:textSize="13sp"
                    android:background="@drawable/tv_btn_focus"
                    android:textColor="#F59E0B"
                    android:focusable="true"
                    android:nextFocusLeft="@id/lvProfiles"/>

                <Button
                    android:id="@+id/btnSplitTunnel"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:text="@string/split_tunneling"
                    android:textSize="13sp"
                    android:background="@drawable/tv_btn_focus"
                    android:textColor="#A78BFA"
                    android:focusable="true"
                    android:nextFocusLeft="@id/lvProfiles"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="6dp"
                    android:background="#333"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/routing_preset"
                    android:textColor="#7C6FFF"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <Spinner
                    android:id="@+id/spinnerPreset"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/tv_btn_focus"
                    android:popupBackground="#2A2A4A"
                    android:focusable="true"
                    android:nextFocusLeft="@id/lvProfiles"/>

                <Button
                    android:id="@+id/btnRules"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:text="@string/routing_rules"
                    android:textSize="13sp"
                    android:background="@drawable/tv_btn_focus"
                    android:textColor="#4ADE80"
                    android:focusable="true"
                    android:nextFocusLeft="@id/lvProfiles"/>

                <Button
                    android:id="@+id/btnIpCheck"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:text="@string/ip_check"
                    android:textSize="14sp"
                    android:background="@drawable/tv_btn_focus"
                    android:textColor="#F59E0B"
                    android:focusable="true"
                    android:nextFocusLeft="@id/lvProfiles"/>

                <Button
                    android:id="@+id/btnUpdateGeo"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:text="@string/update_geo"
                    android:textSize="13sp"
                    android:background="@drawable/tv_btn_focus"
                    android:textColor="#60A5FA"
                    android:focusable="true"
                    android:nextFocusLeft="@id/lvProfiles"/>

                <Button
                    android:id="@+id/btnUpdateApp"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:text="@string/update_app"
                    android:textSize="13sp"
                    android:background="@drawable/tv_btn_focus"
                    android:textColor="#F472B6"
                    android:focusable="true"
                    android:nextFocusLeft="@id/lvProfiles"/>

                <Button
                    android:id="@+id/btnLanguage"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:text="@string/language"
                    android:textSize="13sp"
                    android:background="@drawable/tv_btn_focus"
                    android:textColor="#F59E0B"
                    android:focusable="true"
                    android:nextFocusLeft="@id/lvProfiles"/>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>
</LinearLayout>
